<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Camera Preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/preview_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Scan guide overlay (white rectangle) -->
    <View
        android:id="@+id/scan_guide"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:background="@drawable/scan_guide_border"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.45" />

    <!-- "Align QR code in frame" label -->
    <TextView
        android:id="@+id/tv_scan_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Align QR code within the frame"
        android:textColor="#CCFFFFFF"
        android:textSize="14sp"
        android:paddingTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/scan_guide"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Result Overlay (full screen, initially GONE) -->
    <com.hoa.paymentchecker.ui.scan.ResultOverlayView
        android:id="@+id/result_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <!-- Settings button (top-right) -->
    <ImageButton
        android:id="@+id/btn_settings"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@android:color/transparent"
        android:contentDescription="Settings"
        android:padding="8dp"
        android:src="@android:drawable/ic_menu_manage"
        android:tint="#FFFFFF"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="12dp" />

    <!-- Logout button (top-left, visible for logged-in guards) -->
    <Button
        android:id="@+id/btn_logout_guard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sign Out"
        android:textSize="12sp"
        android:background="#66000000"
        android:textColor="#FFFFFF"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_margin="12dp" />

    <!-- Torch button (bottom-right) -->
    <Button
        android:id="@+id/btn_torch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="💡"
        android:textSize="22sp"
        android:background="#66000000"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="24dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
