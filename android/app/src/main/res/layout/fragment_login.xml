<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F8FAFC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:paddingTop="64dp"
        android:paddingBottom="64dp">

        <!-- Logo -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="40dp">

            <TextView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="#1A6B7B"
                android:text="🏠"
                android:textSize="36sp"
                android:gravity="center"
                android:layout_gravity="center"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HOA Connect"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#1A3A4A"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sign in to continue"
                android:textSize="14sp"
                android:textColor="#5A7A84"
                android:gravity="center"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@android:color/white"
            android:padding="24dp"
            android:elevation="4dp">

            <!-- Username -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Username"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#374151"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/et_username"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/input_background"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:hint="Enter username"
                android:textSize="15sp"
                android:inputType="text"
                android:imeOptions="actionNext"
                android:layout_marginBottom="16dp" />

            <!-- Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Password"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#374151"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/et_password"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/input_background"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:hint="Enter password"
                android:textSize="15sp"
                android:inputType="textPassword"
                android:imeOptions="actionDone"
                android:layout_marginBottom="8dp" />

            <!-- Error -->
            <TextView
                android:id="@+id/tv_error"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="13sp"
                android:textColor="#DC2626"
                android:layout_marginBottom="16dp"
                android:visibility="gone" />

            <!-- Sign In Button -->
            <Button
                android:id="@+id/btn_login"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Sign In"
                android:textSize="15sp"
                android:textStyle="bold"
                android:backgroundTint="#1A6B7B"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- Settings link -->
        <TextView
            android:id="@+id/tv_settings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙ Server Settings"
            android:textSize="13sp"
            android:textColor="#2A9DB5"
            android:layout_marginTop="24dp"
            android:padding="8dp" />

        <!-- Demo Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="32dp"
            android:background="#1A3A4A"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TRY A DEMO ACCOUNT"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#2A9DB5"
                android:letterSpacing="0.1"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Explore the app without creating an account"
                android:textSize="12sp"
                android:textColor="#8AB4BC"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btn_demo_homeowner"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="🏠  Demo as Homeowner"
                android:textSize="13sp"
                android:textStyle="bold"
                android:backgroundTint="#3E9142"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_demo_guard"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="🛡️  Demo as Guard"
                android:textSize="13sp"
                android:textStyle="bold"
                android:backgroundTint="#D97706" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
