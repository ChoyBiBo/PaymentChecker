<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8FAFC">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A6B7B"
        android:padding="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_greeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome back!"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_period"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#B2E0E8"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/btn_logout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sign Out"
            android:textColor="#B2E0E8"
            android:textSize="13sp"
            android:padding="8dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Announcement Banner (scrolling) -->
            <ViewFlipper
                android:id="@+id/vf_announcements"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="130dp"
                android:autoStart="true"
                android:flipInterval="5000"
                android:inAnimation="@android:anim/slide_in_left"
                android:outAnimation="@android:anim/slide_out_right"
                android:layout_marginBottom="12dp"
                android:background="#0F4D59"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="20dp"
                android:paddingBottom="20dp"
                android:elevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📢  ANNOUNCEMENTS"
                        android:textColor="#7DD3E8"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12" />
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Loading announcements..."
                        android:textColor="#B2E0E8"
                        android:textSize="14sp"
                        android:layout_marginTop="6dp" />
                </LinearLayout>
            </ViewFlipper>

            <!-- Payment Status Card -->
            <LinearLayout
                android:id="@+id/card_payment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@android:color/white"
                android:padding="16dp"
                android:elevation="2dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Payment Status"
                    android:textStyle="bold"
                    android:textSize="15sp"
                    android:textColor="#1A3A4A"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tv_payment_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="UPDATED"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:padding="8dp"
                        android:textColor="#FFFFFF"
                        android:background="#3E9142"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_payment_detail"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="13sp"
                            android:textColor="#374151" />

                        <TextView
                            android:id="@+id/tv_paid_at"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:textColor="#5A7A84" />
                    </LinearLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E2E8F0"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp" />

                <!-- Submit Proof button -->
                <TextView
                    android:id="@+id/btn_submit_proof"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📤  Submit Payment Proof&#10;Upload your receipt for this month"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="#0EA5E9"
                    android:padding="14dp"
                    android:layout_marginBottom="12dp"
                    android:elevation="2dp"
                    android:letterSpacing="0.01" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tv_months_behind"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="#1A6B7B" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Months Behind"
                            android:textSize="11sp"
                            android:textColor="#5A7A84" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tv_total_year"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="₱0"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="#1A6B7B" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Paid This Year"
                            android:textSize="11sp"
                            android:textColor="#5A7A84" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Amenities Quick View -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@android:color/white"
                android:padding="16dp"
                android:elevation="2dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Amenities"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="#1A3A4A" />

                    <TextView
                        android:id="@+id/btn_view_amenities"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View All →"
                        android:textColor="#2A9DB5"
                        android:textSize="13sp"
                        android:padding="4dp" />
                </LinearLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/ll_amenities"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingBottom="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Loading..."
                            android:textColor="#5A7A84"
                            android:textSize="13sp" />
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

            <!-- My Requests -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@android:color/white"
                android:padding="16dp"
                android:elevation="2dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="My Booking Requests"
                        android:textStyle="bold"
                        android:textSize="15sp"
                        android:textColor="#1A3A4A" />

                    <TextView
                        android:id="@+id/btn_view_my_bookings"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="View All →"
                        android:textColor="#2A9DB5"
                        android:textSize="13sp"
                        android:padding="4dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_my_requests"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loading..."
                        android:textColor="#5A7A84"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- My Vehicles -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@android:color/white"
                android:padding="16dp"
                android:elevation="2dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🚗  My Vehicles"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A3A4A" />

                    <TextView
                        android:id="@+id/btn_view_vehicles"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Manage →"
                        android:textColor="#2A9DB5"
                        android:textSize="13sp"
                        android:padding="4dp" />
                </LinearLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/ll_vehicle_circles"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingBottom="4dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Loading..."
                            android:textColor="#94A3B8"
                            android:textSize="13sp" />
                    </LinearLayout>
                </HorizontalScrollView>
            </LinearLayout>

            <!-- Renovation Permit -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@android:color/white"
                android:padding="16dp"
                android:elevation="2dp"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🏠  Renovation Permit"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#1A3A4A" />

                    <TextView
                        android:id="@+id/btn_view_renovation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Apply →"
                        android:textColor="#2A9DB5"
                        android:textSize="13sp"
                        android:padding="4dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Submit and track your house renovation permit request."
                    android:textColor="#5A7A84"
                    android:textSize="13sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
