<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@android:color/white">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Request Amenity"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1E293B"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/tv_amenity_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="#64748B"
        android:layout_marginBottom="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Date"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#374151"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/et_date"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/input_background"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:hint="YYYY-MM-DD"
        android:inputType="date"
        android:textSize="14sp"
        android:layout_marginBottom="12dp"
        android:focusable="false"
        android:clickable="true" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginEnd="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Start Time"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#374151"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/et_time_start"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/input_background"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:hint="HH:MM"
                android:inputType="time"
                android:textSize="14sp"
                android:focusable="false"
                android:clickable="true" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="End Time"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#374151"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/et_time_end"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/input_background"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:hint="HH:MM"
                android:inputType="time"
                android:textSize="14sp"
                android:focusable="false"
                android:clickable="true" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Purpose (optional)"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#374151"
        android:layout_marginBottom="4dp" />

    <EditText
        android:id="@+id/et_purpose"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@drawable/input_background"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:hint="Describe your purpose..."
        android:inputType="textMultiLine"
        android:textSize="14sp"
        android:gravity="top"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tv_request_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="13sp"
        android:textColor="#DC2626"
        android:layout_marginBottom="8dp"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">

        <Button
            android:id="@+id/btn_cancel_request"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Cancel"
            android:backgroundTint="#E2E8F0"
            android:textColor="#374151"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btn_submit_request"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Submit Request"
            android:backgroundTint="#1E40AF" />
    </LinearLayout>
</LinearLayout>
